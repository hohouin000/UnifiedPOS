{
  "ConnectionStrings": {
    "UnifiedPOSDb": "Data Source=data/UnifiedPOS.db"
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:5000"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    },
    "File": {
      "Path": "logs/unifiedpos-.log",
      "RollingInterval": "Day",
      "RetainedFileCount": 30
    }
  },
  "AllowedHosts": "*"
}